# HOW TO USE: copy this file to `server/.env` and paste your real values after the
# `=` signs. The server auto-loads `server/.env` at startup (see server/env.js) —
# no extra step. `.env` is gitignored, so your keys never get committed. Values set
# in the shell or by your host (Render/Railway/Docker) override the file.
# Leave a line blank to keep that integration in safe mock mode.
#
# --- Dev (default): runs fully offline with mock LLM + sample data ---
PORT=8787

# Sites allowed to call this AI API cross-domain (the main product website).
# Comma-separated; unset = allow all (dev only).
# e.g. https://scoutfoxgo.com,https://www.scoutfoxgo.com
ALLOWED_ORIGINS=

# Optional shared key for the dev team's server-to-server calls. If set, /api
# requires X-API-Key (or Authorization: Bearer). Unset = open (dev).
SCOUTFOX_API_KEY=

# --- LIVE data ---
# Refuse to serve any placeholder/mock content. With this set, every integration
# below must be configured or requests fail loudly (never with fake data).
LIVE_ONLY=

# Real Claude responses (LLM, synthesis, judge, tutor, research, NL parsing).
ANTHROPIC_API_KEY=

# Live ScoutFoxGo data (trips, trip_days, family_profiles, scrapbook). Point this
# at your ScoutFoxGo endpoint that returns the master-file JSON shape. Without it
# (and with LIVE_ONLY off) the bundled sample seed is used for dev only.
SCOUTFOXGO_DATA_URL=

# Booking partners — live inventory for the Decision Layer. Each adapter uses
# real data when its key is present; in LIVE_ONLY mode a missing key fails loudly.
# Duffel = real flight search (and, later, booking). Set the key to go live on
# POST /api/flights/search. DUFFEL_VERSION must match Duffel's current API
# version header (check their docs; default "v2").
DUFFEL_API_KEY=
DUFFEL_VERSION=v2
KAYAK_API_KEY=

# Booking.com affiliate (hotels/stays) — you have an affiliate account.
BOOKING_AFFILIATE_ID=
BOOKING_API_KEY=

# Expedia Group / EPS Rapid affiliate (hotels/flights/activities).
EXPEDIA_API_KEY=
EXPEDIA_SHARED_SECRET=

# PHPtravels — your SELF-HOSTED install (not a cloud API). Set the base URL of your
# install + an API key created in its admin. The license key activates the software
# on your machine; it does NOT go here. See API_DOCS.md.
PHPTRAVELS_BASE_URL=
PHPTRAVELS_API_KEY=

# Activities / cruises inventory (unified inventory engine). Each is optional;
# missing key = mock in dev, fails loudly in LIVE_ONLY.
VIATOR_API_KEY=
GETYOURGUIDE_API_KEY=
CRUISE_API_KEY=

# Enrichment signals — real places + community sentiment feeding the Finder
# engines and the Match Score. Optional; all degrade to mock without a key.
GOOGLE_PLACES_API_KEY=
REDDIT_API_KEY=
SOCIAL_SENTIMENT_API_KEY=

# Flight BOOKING (test mode). Stripe collects the customer's payment; Duffel
# issues the ticket. Use TEST keys — bookings refuse to run with live keys
# unless ALLOW_LIVE_PAYMENTS=true (which charges real money). Leave that unset.
STRIPE_SECRET_KEY=
ALLOW_LIVE_PAYMENTS=
